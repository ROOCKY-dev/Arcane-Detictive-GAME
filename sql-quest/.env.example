# =============================================================================
# SQL Quest — Environment Variables
# Copy this file to .env.local and fill in your values.
# The app runs fully in guest mode (localStorage only) without Supabase.
# =============================================================================

# ─── Supabase (optional — enables auth, cloud sync, and teacher dashboard) ───
# Create a project at https://supabase.com and find these in:
# Project Settings → API → Project URL / anon public key

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# ─── Notes ────────────────────────────────────────────────────────────────────
# • Without Supabase the game works 100% offline — progress saved to localStorage.
# • Run `npm run build:db` once after cloning to generate the .sqlite files under
#   public/databases/ (requires Node.js — uses better-sqlite3 at build time only).
# • The custom_databases Storage bucket must be created in Supabase before
#   teachers can upload compiled quest databases via the Quest Forge.
# • Apply supabase/migrations/20260306_rls_policies.sql in the Supabase SQL Editor
#   before going to production.
